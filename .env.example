# =========================
# App / Auth
# =========================
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# =========================
# Google OAuth / Gmail API (optional; required only for Gmail scanning)
# Scope used: openid email profile https://www.googleapis.com/auth/gmail.readonly
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =========================
# MongoDB Atlas
# =========================
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/careermaxing?retryWrites=true&w=majority
MONGODB_DB=careermaxing

# =========================
# OpenAI (optional; app runs in mock mode without it)
# =========================
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
# Set to "true" to enable real LLM calls. Default false keeps cost at $0.
LLM_ENABLED=false

# =========================
# Real data sources (free, no key required)
# Remotive (jobs) and Devpost (hackathons) both work with $0 / zero keys.
# =========================
REMOTIVE_API_BASE=https://remotive.com/api/remote-jobs

# Optional Job APIs (gated by env presence — currently unused; placeholders kept for future)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
THEMUSE_API_KEY=

# =========================
# App Config
# =========================
APP_NAME=CareerMaxing
APP_ENV=development
# Legacy LLM mock switch. Resource scans still require verified Remotive/Devpost/curated URLs.
USE_MOCK_DATA=true
